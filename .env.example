# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_MODEL=gpt-5.4
OPENAI_JUDGE_MODEL=gpt-5-mini
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# PromptForge
PF_APP_ENV=local
PF_LOG_LEVEL=INFO
PF_PROMPT_PACK_DIR=prompt_packs
PF_DATASET_DIR=datasets
PF_VAR_DIR=var
PF_PROVIDER=openai
PF_JUDGE_PROVIDER=
PF_DEFAULT_TIMEOUT_SECONDS=60
PF_DEFAULT_MAX_OUTPUT_TOKENS=800
PF_DEFAULT_RETRIES=2
PF_DEFAULT_CONCURRENCY=8
PF_DEFAULT_FAILURE_THRESHOLD=0.40
PF_STDOUT_LOGS=false
PF_CODEX_BIN=codex
PF_CODEX_PROFILE=
PF_CODEX_REASONING_EFFORT=medium
PF_CODEX_SANDBOX=read-only
